# Copy to .env.local and fill in values

# Backend proxy base (ramanchada-api / nambit backend)
VITE_API_URL=https://nambit.adma.ai/api

# Solr collections (via API proxy)
VITE_PREDICTIONS_CORE=predictions
VITE_CHEMICALS_CORE=chemicals

# HSDS / h5web integration
VITE_HSDS_URL=https://hsds.adma.ai
VITE_HSDS_DOMAIN=/qubounds
